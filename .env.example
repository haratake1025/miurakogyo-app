# ============================================================
# サーバー専用シークレット（クライアントバンドルに含まれない）
# ============================================================

# CBO (Craft Bank Office) API
CBO_BASE_URL=https://office.craft-bank.com/api
CBO_TOKEN=
CBO_COMPANY_ID=4083
CBO_SUPPLIER_VIEW_ID=2744
# CBO報告者ID（workers.reporter_cbo_user_id が未設定の場合のフォールバック）
CBO_DEFAULT_REPORTER_ID=

# Supabase（サーバー専用 — service_role は絶対に NEXT_PUBLIC_ にしない）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# クライアント公開キー（ブラウザから参照される）
# ============================================================

# Supabase Auth 用（anon key は公開してよい）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
